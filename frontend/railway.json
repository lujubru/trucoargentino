{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "CI=false yarn install && CI=false yarn build",
    "nixpacksVersion": "1.29.1"
  },
  "deploy": {
    "startCommand": "npx serve -s build -l ${PORT:-3000}",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30
  }
}
